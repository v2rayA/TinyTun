{
  "log": {
    "loglevel": "info",
    "hide_timestamp": false
  },
  "tun": {
    "name": "tun0",
    "ip": "198.18.0.1",
    "netmask": "255.255.255.255",
    "ipv6_mode": "auto",
    "auto_route": true,
    "mtu": 1500
  },
  "socks5": {
    "address": "127.0.0.1:1080",
    "username": null,
    "password": null
  },
  "dns": {
    "groups": [
      {
        "name": "direct",
        "servers": ["114.114.114.114:53", "223.5.5.5:53"],
        "protocol": "udp",
        "strategy": "concurrent",
        "upstream": "direct"
      },
      {
        "name": "proxy",
        "servers": ["8.8.8.8:53", "1.1.1.1:53"],
        "protocol": "udp",
        "strategy": "concurrent",
        "upstream": "proxy"
      },
      {
        "_comment": "DoT example — remove _comment and rename to enable",
        "_name": "proxy-dot",
        "_servers": ["8.8.8.8:853", "1.1.1.1:853"],
        "_protocol": "dot",
        "_sni": "dns.google",
        "_strategy": "concurrent",
        "_upstream": "proxy"
      },
      {
        "_comment": "DoH example — servers must be HTTPS URLs",
        "_name": "proxy-doh",
        "_servers": [
          "https://dns.google/dns-query",
          "https://cloudflare-dns.com/dns-query"
        ],
        "_protocol": "doh",
        "_strategy": "concurrent",
        "_upstream": "proxy"
      },
      {
        "_comment": "DoQ example — QUIC cannot traverse SOCKS5, upstream is always direct",
        "_name": "proxy-doq",
        "_servers": ["dns.google:853", "dns.cloudflare.com:853"],
        "_protocol": "doq",
        "_strategy": "concurrent",
        "_upstream": "direct"
      }
    ],
    "listen_port": 53,
    "timeout_ms": 5000,
    "routing": {
      "rules": [
        {
          "matcher": {"type": "geosite", "file": "/etc/v2ray/geosite.dat", "tag": "category-ads-all"},
          "reject": true
        },
        {
          "matcher": {"type": "geosite", "file": "/etc/v2ray/geosite.dat", "tag": "cn"},
          "group": "direct"
        },
        {
          "matcher": {"type": "wildcard"},
          "group": "proxy"
        }
      ],
      "fallback_group": "proxy",
      "enable_cache": true,
      "cache_capacity": 4096
    }
  },
  "filtering": {
    "skip_ips": ["127.0.0.1", "::1", "198.18.0.1"],
    "skip_networks": [
      "127.0.0.0/8",
      "169.254.0.0/16",
      "::1/128",
      "fc00::/7",
      "fe80::/10"
    ],
    "block_ports": [],
    "allow_ports": [80, 443, 53],
    "exclude_processes": []
  },
  "route": {
    "auto_detect_interface": true
  }
}